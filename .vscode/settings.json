{
    "workbench.colorTheme": "Gotham",
    "editor.minimap.enabled": false,
    "workbench.activityBar.location": "hidden",
    "workbench.statusBar.visible": false,
    "editor.lineNumbers": "off",
    "editor.wordWrap": "on",
    "cSpell.language": ["en", "zh-CN"],
    "cSpell.dictionaries": ["chinese"],
    "editor.renderWhitespace": "none",
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": false,
    "editor.matchBrackets": "never",
    "editor.glyphMargin": false,
    "editor.folding": false,
    "editor.renderLineHighlight": "none",
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.fontSize": 16,
    "editor.lineHeight": 28,
    "editor.fontFamily": "'JetBrains Mono', 'Microsoft YaHei', 'LXGW WenKai', 'Source Han Serif SC', 'FangSong', sans-serif",
    "editor.fontLigatures": true,
    "editor.fontWeight": "normal",
    "workbench.colorCustomizations": {
        "[Gotham]": {
            "editor.background": "#0a0b10",
            "sideBar.background": "#06070a",
            "editorWidget.background": "#0d0e14",
            "titleBar.activeBackground": "#06070a",
            "activityBar.background": "#06070a",
            "statusBar.background": "#06070a"
        }
    },
    "python.defaultInterpreterPath": "D:\\python\\python.exe",
    "python.terminal.activateEnvironment": true,
    "python.analysis.typeCheckingMode": "basic",
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-25",
            "path": "E:\\Development\\JDK25",
            "default": true
        }
    ],
    "java.compile.nullAnalysis.mode": "automatic"
}
